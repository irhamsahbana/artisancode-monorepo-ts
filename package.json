{
  "name": "artisancode-monorepo",
  "private": true,
  "workspaces": [
    "api",
    "web",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "test": "bun run --filter artisancode-backend-ts test:unit",
    "test:unit": "bun run --filter artisancode-backend-ts test:unit",
    "test:integration": "bun run --filter artisancode-backend-ts test:integration",
    "lint": "bun run --filter '*' lint",
    "format": "bun run --filter '*' format",
    "lint:fix": "bun run --filter '*' lint:fix",
    "type-check": "bun run --filter '*' type-check",
    "prepare": "husky"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "husky": "^9.1.7",
    "web": "^0.0.2"
  }
}
