{
  "name": "artisancode-backend-ts",
  "version": "1.0.0",
  "type": "module",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "bun run test:unit",
    "test:unit": "bun test src/modules/ src/common/store/ src/common/middlewares/",
    "test:packages": "bun test src/__tests__/packages/",
    "test:integration": "bun test src/__tests__/",
    "build": "rm -rf dist && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "build:binary": "bun build --compile --minify --sourcemap --target=bun src/index.ts --outfile dist/api && rm -f .*.bun-build",
    "start": "bun dist/index.js",
    "dev": "bun --watch src/index.ts",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:migrate": "drizzle-kit migrate",
    "drizzle:push": "drizzle-kit push",
    "drizzle:studio": "drizzle-kit studio",
    "drizzle:pull": "drizzle-kit pull",
    "drizzle:seed": "bun src/db/seed.ts",
    "test:doku": "bunx tsx scripts/test_doku.ts",
    "lint": "eslint --ext .ts src --fix",
    "format": "prettier --write \"src/**/*.{ts,js,json}\"",
    "lint:fix": "eslint --ext .ts src --fix && prettier --write \"src/**/*.{ts,js,json}\"",
    "type-check": "tsc --noEmit",
    "lint-staged": "lint-staged"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "bun@1.3.6",
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "@artisancode/api-types": "workspace:*",
    "@artisancode/http-client": "workspace:*",
    "@artisancode/logger": "workspace:*",
    "@artisancode/logger-pino": "workspace:*",
    "@artisancode/observability": "workspace:*",
    "@artisancode/resilience": "workspace:*",
    "@artisancode/types": "workspace:*",
    "@aws-sdk/client-s3": "^3.1067.0",
    "@aws-sdk/s3-request-presigner": "^3.1067.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.210.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.210.0",
    "@opentelemetry/instrumentation-winston": "^0.53.0",
    "@opentelemetry/resources": "^2.4.0",
    "@opentelemetry/sdk-logs": "^0.210.0",
    "@opentelemetry/sdk-node": "^0.210.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.38.0",
    "@opentelemetry/winston-transport": "^0.20.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node-cron": "^3.0.11",
    "bcrypt": "^6.0.0",
    "cockatiel": "^4.0.0",
    "doku-nodejs-library": "^1.0.52",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.25",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "zod": "^4.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@faker-js/faker": "^10.2.0",
    "@testcontainers/postgresql": "^12.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.1.0",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.3",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4",
    "testcontainers": "^12.0.1",
    "ts-mockito": "^2.6.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0"
  },
  "trustedDependencies": [
    "protobufjs",
    "unrs-resolver"
  ]
}
