# Basic config
APP_ENV=development
APP_NAME=artisancode-backend-ts
APP_VERSION=1.0.0

REST_PORT=3002

# CORS
# Comma-separated list of allowed Origins (scheme + host + port).
# - Development: if empty, all browser origins are allowed (reflected by the server).
# - Production: if empty, browser requests are blocked unless Origin is absent (server-to-server).
# Example: CORS_ORIGINS=http://localhost:5173,https://app.example.com
CORS_ORIGINS=
# If true, allows sending cookies/authorization headers cross-origin.
CORS_ALLOW_CREDENTIALS=true

# Database
DATABASE_URL="prisma+postgres://localhost:51213/?api_key=an_api_key"

# OpenTelemetry
# Toggle OpenTelemetry on/off
OTEL_ENABLED=false
# Sampling ratio (0-1): 1 = all requests, 0.1 = 10% of requests
OTEL_SAMPLING_RATIO=1
# Base OTLP endpoint (US: https://otlp.nr-data.net, EU: https://otlp.eu01.nr-data.net)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Override traces endpoint (defaults to {ENDPOINT}/v1/traces)
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
# Override logs endpoint (defaults to {ENDPOINT}/v1/logs)
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://localhost:4318/v1/logs
# Headers (comma-separated, e.g. api-key=<license_key>)
OTEL_EXPORTER_OTLP_HEADERS=
# Max attribute value length (auto-read by OTel SDK, no code config needed)
OTEL_ATTRIBUTE_VALUE_LENGTH_LIMIT=4095
# Compression algorithm: gzip or none
OTEL_EXPORTER_OTLP_COMPRESSION=gzip
# Diagnostic log level: all, verbose, debug, info, warn, error, none
OTEL_DIAG_LOG_LEVEL=error

# DOKU Payment Gateway
DOKU_CLIENT_ID=
DOKU_SHARED_KEY=
API_BASE_URL=http://localhost:3002/api
