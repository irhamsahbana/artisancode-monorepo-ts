# Docker Compose — dipakai saat `docker compose up`

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=wika

# Port mapping ke host (opsional, ada default)
API_PORT=3002
WEB_PORT=3000

# API
APP_NAME=artisancode-backend-ts
APP_VERSION=1.0.0
CORS_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=true

# OpenTelemetry (opsional)
OTEL_ENABLED=false

# DOKU Payment Gateway (opsional)
DOKU_CLIENT_ID=
DOKU_SHARED_KEY=
API_BASE_URL=http://localhost:3002/api

# Web — URL API yang diakses browser (ganti ke domain production)
BUN_PUBLIC_API_URL=http://localhost:3002
